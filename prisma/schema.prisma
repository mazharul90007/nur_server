generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Surah {
  number          Int     @id
  nameArabic      String  @db.Text
  nameEnglish     String  @db.Text
  nameEnglishLong String? @db.Text
  revelationPlace String
  revelationOrder Int
  versesCount     Int
  bismillahPre    Boolean

  ayahs Ayah[]
}

model Ayah {
  id            Int     @id @default(autoincrement())
  surahNumber   Int
  surah         Surah   @relation(fields: [surahNumber], references: [number], onDelete: Cascade)
  numberInSurah Int
  textArabic    String  @db.Text
  bismillah     String? @db.Text

  translations AyahTranslation[]

  @@unique([surahNumber, numberInSurah])
  @@index([surahNumber])
}

model TranslationEdition {
  id       Int    @id @default(autoincrement())
  code     String @unique
  language String
  name     String

  translations AyahTranslation[]
}

model AyahTranslation {
  id        Int                @id @default(autoincrement())
  ayahId    Int
  ayah      Ayah               @relation(fields: [ayahId], references: [id], onDelete: Cascade)
  editionId Int
  edition   TranslationEdition @relation(fields: [editionId], references: [id], onDelete: Cascade)
  text      String             @db.Text

  @@unique([ayahId, editionId])
  @@index([editionId])
}
